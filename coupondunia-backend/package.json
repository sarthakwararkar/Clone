{
  "name": "coupondunia-backend",
  "version": "1.0.0",
  "description": "CouponDunia clone backend — coupon & cashback aggregator for India",
  "type": "module",
  "scripts": {
    "dev": "node ../sync-env.js && wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "node ../sync-env.js && drizzle-kit generate",
    "db:push": "node ../sync-env.js && drizzle-kit push",
    "db:migrate": "node ../sync-env.js && drizzle-kit migrate",
    "db:studio": "node ../sync-env.js && drizzle-kit studio",
    "seed": "node ../sync-env.js && npx tsx src/jobs/seed.ts",
    "scrape": "node ../sync-env.js && npx tsx src/jobs/scrapePublicDeals.ts",
    "sync": "node ../sync-env.js && npx tsx src/jobs/syncCoupons.ts",
    "jobs:sync": "node ../sync-env.js && npx tsx src/jobs/syncCoupons.ts",
    "jobs:expire": "node ../sync-env.js && npx tsx src/jobs/expireCoupons.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@supabase/supabase-js": "^2.45.0",
    "@upstash/qstash": "^2.7.0",
    "@upstash/redis": "^1.34.3",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "resend": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241018.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.27.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.80.0"
  }
}
